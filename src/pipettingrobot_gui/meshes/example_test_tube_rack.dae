    <up_axis>Z_UP</up_axis>
  </asset>
  <library_effects>
    <effect id="rack-effect">
      <profile_COMMON>
        <technique sid="common">
          <phong>
            <diffuse>
              <color>0.75 0.75 0.82 0.55</color>
            </diffuse>
          </phong>
        </technique>
      </profile_COMMON>
    </effect>
  </library_effects>
  <library_materials>
    <material id="rack-material" name="rack-material">
