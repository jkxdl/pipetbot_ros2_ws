    </material>
  </library_materials>
  <library_geometries>
    <geometry id="rack-geometry" name="rack-geometry">
      <mesh>
        <source id="rack-positions">
          <float_array id="rack-positions-array" count="24">-0.5 -0.25 0 0.5 -0.25 0 0.5 0.25 0 -0.5 0.25 0 -0.5 -0.25 0.5 0.5 -0.25 0.5 0.5 0.25 0.5 -0.5 0.25 0.5</float_array>
          <technique_common>
            <accessor source="#rack-positions-array" count="8" stride="3">
              <param name="X" type="float"/>
              <param name="Y" type="float"/>
              <param name="Z" type="float"/>
            </accessor>
          </technique_common>
        </source>
        <vertices id="rack-vertices">
          <input semantic="POSITION" source="#rack-positions"/>
        </vertices>
        <triangles count="12" material="rack-material">
          <input semantic="VERTEX" source="#rack-vertices" offset="0"/>
          <p>0 1 2 0 2 3 0 1 5 0 5 4 1 2 6 1 6 5 2 3 7 2 7 6 3 0 4 3 4 7 4 5 6 4 6 7 0 3 2 0 2 1</p>
        </triangles>
