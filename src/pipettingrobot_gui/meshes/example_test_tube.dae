    <unit name="meter" meter="1"/>
    <up_axis>Z_UP</up_axis>
  </asset>
  <library_effects>
    <effect id="tube-effect">
      <profile_COMMON>
        <technique sid="common">
          <phong>
            <diffuse>
              <color>0.85 0.90 0.98 0.35</color>
            </diffuse>
          </phong>
        </technique>
      </profile_COMMON>
    </effect>
  </library_effects>
  <library_materials>
    <material id="tube-material" name="tube-material">
      <instance_effect url="#tube-effect"/>
    </material>
  </library_materials>
  <library_geometries>
    <geometry id="tube-geometry" name="tube-geometry">
      <mesh>
        <source id="tube-positions">
          <float_array id="tube-positions-array" count="24">-0.5 -0.5 0 0.5 -0.5 0 0.5 0.5 0 -0.5 0.5 0 -0.35 -0.35 1 0.35 -0.35 1 0.35 0.35 1 -0.35 0.35 1</float_array>
          <technique_common>
            <accessor source="#tube-positions-array" count="8" stride="3">
              <param name="X" type="float"/>
              <param name="Y" type="float"/>
              <param name="Z" type="float"/>
            </accessor>
          </technique_common>
        </source>
        <vertices id="tube-vertices">
          <input semantic="POSITION" source="#tube-positions"/>
        </vertices>
        <triangles count="12" material="tube-material">
          <input semantic="VERTEX" source="#tube-vertices" offset="0"/>
          <p>0 1 2 0 2 3 0 1 5 0 5 4 1 2 6 1 6 5 2 3 7 2 7 6 3 0 4 3 4 7 4 5 6 4 6 7</p>
        </triangles>
      </mesh>
    </geometry>
  </library_geometries>
  <library_visual_scenes>
    <visual_scene id="Scene" name="Scene">
      <node id="tube-node" name="tube-node">
        <instance_geometry url="#tube-geometry">
          <bind_material>
            <technique_common>
              <instance_material symbol="tube-material" target="#tube-material"/>
            </technique_common>
          </bind_material>
        </instance_geometry>
      </node>
    </visual_scene>
  </library_visual_scenes>
  <scene>
    <instance_visual_scene url="#Scene"/>
  </scene>
